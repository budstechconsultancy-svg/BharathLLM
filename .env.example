# Core
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key_here
HF_TOKEN=your_huggingface_token_here
MODEL_NAME=meta-llama/Llama-3.1-8B-Instruct
MODELS_DIR=/models

# Auth
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=8
ADMIN_MASTER_KEY=your_admin_master_key_here

# Database (PostgreSQL for structured data + user management)
DATABASE_URL=postgresql://user:password@localhost:5432/bharatllm
POSTGRES_DB=bharatllm
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password_here

# Fix 4.1: DB Connection Pooling (tune for production load)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30

# Redis + Celery
REDIS_URL=redis://localhost:6379/0

# Fix 4.2: Redis LLM Response Cache TTL (seconds)
CACHE_TTL_SECONDS=3600


# API
API_SECRET_KEY=your_api_secret_key_here
ALLOWED_ORIGINS=https://llm.tn.gov.in,https://health.tn.gov.in

# Frontend (Vite reads these at build time)
VITE_API_URL=https://llm.tn.gov.in/api/v1
VITE_DEPLOYMENT_MODE=STATE_GOVT
VITE_STATE_NAME=Tamil Nadu
VITE_DEPLOYMENT_LABEL=BharatLLM

# Storage paths
RAW_DIR=/data/raw
PROCESSED_DIR=/data/processed
CLEANED_DIR=/data/cleaned
CHUNKS_DIR=/data/chunks
TRAINING_DIR=/data/training
LOG_DIR=/logs

# Web Search APIs
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=
SERPAPI_KEY=
WEB_SEARCH_PROVIDER=tavily

# Web search behaviour
WEB_SEARCH_ENABLED=true
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TIMEOUT_SEC=8
GOV_DOMAINS_ONLY_FIRST=true
WEB_SEARCH_DAILY_LIMIT=500

# Agent settings
MAX_AGENT_STEPS=20
AGENT_TIMEOUT_SEC=300
HUMAN_APPROVAL_REQUIRED=true
SANDBOX_TIMEOUT_SEC=30

# Email (SendGrid)
SENDGRID_API_KEY=
FROM_EMAIL=noreply@bharatllm.in

# SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Code sandbox (E2B)
E2B_API_KEY=

# Govt API integrations
DIGILOCKER_CLIENT_ID=
DIGILOCKER_CLIENT_SECRET=
PFMS_API_KEY=
EOFFICE_API_KEY=

# Voice Engine
VOICE_ENGINE=whisper_local
WHISPER_MODEL_SIZE=medium
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
TTS_ENABLED=true
TTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2
VOICE_MAX_DURATION_SEC=120

# Vision Engine
VISION_ENGINE=llava_local
LLAVA_MODEL_PATH=/models/llava/llava-v1.6-mistral-7b.Q4_K_M.gguf
LLAVA_CLIP_PATH=/models/llava/mmproj-model-f16.gguf
OPENAI_API_KEY=
VISION_MAX_IMAGE_SIZE_MB=10
VISION_DETECT_TYPE=true
